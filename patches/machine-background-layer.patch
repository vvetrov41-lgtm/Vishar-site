From: Claude
Subject: [PATCH] homepage: 3D machine becomes background layer after assembly

Reworks the homepage 3D tattoo machine so the existing scroll-driven
assembly is preserved, and after assembly the machine becomes a
fixed background layer behind subsequent homepage sections,
visible until the end of #ai-assistant. The canvas never appears
over or behind the Hero, never intercepts pointer events, and the
render loop runs only inside the active range.

Changes are limited to index.html.

---
 index.html | 38 ++++++++++++++++++++++++++------------
 1 file changed, 26 insertions(+), 12 deletions(-)

diff --git a/index.html b/index.html
--- a/index.html
+++ b/index.html
@@
 <body class="antialiased">
 
+    <!-- 3D machine background layer (canvas mounted here by the 3D script). Sits behind all page content. -->
+    <div id="machine-bg" aria-hidden="true" style="position:fixed;inset:0;z-index:0;pointer-events:none;opacity:0;transition:opacity .6s ease;contain:strict;will-change:opacity"></div>
+
     <!-- Nav (injected by components.js) -->
     <div id="site-nav"></div>
 
     <!-- Hero -->
-    <main>
+    <main style="position:relative;z-index:1">
     <header class="relative h-[95vh] flex items-center justify-center text-center px-6 overflow-hidden">
@@
     <!-- ═══ 3D INDUCTION TATTOO MACHINE — Scroll Assembly ═══ -->
     <section id="machine-section" aria-label="3D Tattoo Machine Animation" style="position:relative;height:150vh;background:#000;overflow:hidden">
-      <div id="machine-canvas-wrap" style="position:sticky;top:0;width:100%;height:100vh;display:flex;align-items:center;justify-content:center">
+      <div id="machine-canvas-wrap" style="position:sticky;top:0;width:100%;height:100vh;display:flex;align-items:center;justify-content:center;pointer-events:none">
@@
     <!-- Portfolio (20 photos) -->
-    <section id="portfolio" class="py-20 md:py-24 px-4 bg-apple-darkGray/30 border-y border-violet-400/10">
+    <section id="portfolio" class="py-20 md:py-24 px-4 border-y border-violet-400/10">
@@
-    <section class="pt-8 pb-6 px-6 border-b border-white/5 bg-black" aria-labelledby="inquiry-process-title">
+    <section class="pt-8 pb-6 px-6 border-b border-white/5" aria-labelledby="inquiry-process-title">
@@
     <!-- AI Assistant -->
-    <section id="ai-assistant" class="py-24 px-6 bg-apple-darkGray/10 border-y border-white/5">
+    <section id="ai-assistant" class="py-24 px-6 border-y border-white/5">

